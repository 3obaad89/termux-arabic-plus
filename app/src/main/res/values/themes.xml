<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Dark theme — GitHub Dark inspired (always dark) -->
    <style name="Theme.TermuxApp.Dark" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/background_dark</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <item name="colorPrimaryContainer">@color/background_secondary</item>
        <item name="colorOnPrimaryContainer">@color/text_primary</item>
        <item name="colorSecondary">@color/accent_green</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="colorSecondaryContainer">@color/background_tertiary</item>
        <item name="colorOnSecondaryContainer">@color/accent_green</item>
        <item name="colorTertiary">@color/accent_pink</item>
        <item name="colorOnTertiary">@color/black</item>
        <item name="colorError">@color/accent_red</item>
        <item name="colorOnError">@color/black</item>
        <item name="android:colorBackground">@color/background_dark</item>
        <item name="colorSurface">@color/background_dark</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/background_secondary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        <item name="colorOutline">@color/border_color</item>
        <item name="android:statusBarColor">@color/background_dark</item>
        <item name="android:navigationBarColor">@color/background_dark</item>
        <!-- Windows -->
        <item name="android:windowBackground">@color/background_dark</item>
        <item name="android:windowActionModeOverlay">true</item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
        <item name="android:windowAllowReturnTransitionOverlap">true</item>
        <item name="android:windowAllowEnterTransitionOverlap">true</item>
    </style>

    <!-- TermuxApp DarkActionBar -->
    <style name="Theme.TermuxApp.Dark.DarkActionBar" parent="Theme.TermuxApp.Dark">
        <item name="android:statusBarColor">@color/background_dark</item>
    </style>

    <!-- TermuxApp NoActionBar -->
    <style name="Theme.TermuxApp.Dark.NoActionBar" parent="Theme.TermuxApp.Dark">
    </style>

    <!-- Keep DayNight variants but make them default to dark -->
    <style name="Theme.TermuxApp.DayNight.DarkActionBar" parent="Theme.TermuxApp.Dark.DarkActionBar"/>
    <style name="Theme.TermuxApp.DayNight.NoActionBar" parent="Theme.TermuxApp.Dark.NoActionBar"/>

    <!-- TermuxActivity NoActionBar -->
    <style name="Theme.TermuxActivity.DayNight.NoActionBar" parent="Theme.TermuxApp.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/background_dark</item>
        <item name="android:windowActionModeOverlay">true</item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
        <item name="android:windowAllowReturnTransitionOverlap">true</item>
        <item name="android:windowAllowEnterTransitionOverlap">true</item>

        <!-- Left drawer -->
        <item name="buttonBarButtonStyle">@style/TermuxActivity.Drawer.ButtonBarStyle.Dark</item>
        <item name="termuxActivityDrawerBackground">@color/background_secondary</item>
        <item name="termuxActivityDrawerImageTint">@color/text_primary</item>

        <!-- Extra keys colors -->
        <item name="extraKeysButtonTextColor">@color/text_primary</item>
        <item name="extraKeysButtonActiveTextColor">@color/accent_green</item>
        <item name="extraKeysButtonBackgroundColor">@color/background_tertiary</item>
        <item name="extraKeysButtonActiveBackgroundColor">@color/accent_green</item>
    </style>

    <!-- Night theme alias for compatibility -->
    <style name="Theme.TermuxApp" parent="Theme.TermuxApp.DayNight.NoActionBar"/>

</resources>
