<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:android="http://schemas.android.com/apk/res/android">

    <style name="TermuxAlertDialogStyle" parent="ThemeOverlay.Material3.Dark.AlertDialog">
        <item name="android:colorAccent">@color/accent_green</item>
    </style>

    <style name="TermuxActivity.Drawer.ButtonBarStyle.Dark" parent="@style/Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/accent_green</item>
    </style>

    <!-- Bottom Quick Key Bar Styles -->
    <style name="BottomKeyBar" parent="">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">42dp</item>
        <item name="android:background">@color/background_secondary</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingHorizontal">4dp</item>
    </style>

    <style name="BottomKeyBar.Button">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:orientation">vertical</item>
        <item name="android:background">@drawable/bottom_key_bg</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:duplicateParentState">true</item>
        <item name="android:paddingVertical">2dp</item>
    </style>

    <style name="BottomKeyBar.KeySymbol">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="BottomKeyBar.KeyLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">8sp</item>
        <item name="android:gravity">center</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:textColor">@color/text_muted</item>
    </style>

    <!-- Top Toolbar style -->
    <style name="TermuxToolbar" parent="Widget.Material3.Toolbar">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:background">@color/background_dark</item>
        <item name="android:paddingHorizontal">8dp</item>
    </style>

</resources>
