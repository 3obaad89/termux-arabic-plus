<?xml version="1.0" encoding="utf-8"?>
<com.termux.app.terminal.TermuxActivityRootView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/activity_termux_root_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#ff0d1117"
    android:fitsSystemWindows="false">

    <!-- 🔷 Toolbar — URL bar style (36dp) like ParrotTerminal -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar_termux"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:background="#ff0d1117"
        android:paddingStart="4dp"
        android:paddingEnd="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Left: Terminal name + dragon emoji -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/active_session_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#ff50fa7b"
                    android:gravity="center_vertical"
                    android:text="@string/default_session_name" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:gravity="center_vertical"
                    android:text="🐉"
                    android:layout_marginStart="4dp" />
            </LinearLayout>

            <Space
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1" />

            <!-- Settings button -->
            <ImageButton
                android:id="@+id/settings_button"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_settings"
                android:scaleType="centerInside"
                android:contentDescription="@string/action_settings"
                android:layout_marginEnd="2dp" />

            <Space
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1" />

            <!-- Disconnect button (red) — same as ParrotTerminal -->
            <TextView
                android:id="@+id/disconnect_button"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#ffff6b6b"
                android:gravity="center"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:focusable="true"
                android:clickable="true"
                android:text="@string/disconnect_label"
                android:contentDescription="@string/disconnect_label"
                android:layout_marginEnd="24dp"
                android:paddingHorizontal="10dp" />

            <!-- New session button (rightmost) -->
            <ImageButton
                android:id="@+id/new_session_button"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_new_session"
                android:scaleType="centerInside"
                android:contentDescription="@string/action_new_session" />

            <!-- Hidden keyboard toggle button (kept for code compatibility) -->
            <ImageButton
                android:id="@+id/toggle_keyboard_button"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />

        </LinearLayout>
    </com.google.android.material.appbar.MaterialToolbar>

    <!-- 🔷 TabLayout — session tabs (26dp, green indicator) like ParrotTerminal -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/session_tab_layout"
        android:layout_width="match_parent"
        android:layout_height="26dp"
        android:background="#ff0d1117"
        android:elevation="1dp"
        app:tabIndicatorColor="#ff50fa7b"
        app:tabIndicatorHeight="2dp"
        app:tabMaxWidth="90dp"
        app:tabMinWidth="48dp"
        app:tabMode="fixed"
        app:tabPaddingEnd="4dp"
        app:tabPaddingStart="4dp"
        app:tabSelectedTextColor="#ff50fa7b"
        app:tabTextColor="#ff8b949e" />

    <!-- 🔷 Main content area — wraps TerminalView + DrawerLayout -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingHorizontal="4dp">

        <!-- Terminal DrawerLayout (always visible) -->
        <androidx.drawerlayout.widget.DrawerLayout
            android:id="@+id/drawer_layout"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <com.termux.view.TerminalView
                android:id="@+id/terminal_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:defaultFocusHighlightEnabled="false" />

            <!-- Session drawer -->
            <LinearLayout
                android:id="@+id/terminal_sessions_list"
                android:layout_width="240dp"
                android:layout_height="match_parent"
                android:layout_gravity="start"
                android:background="#ff161b22"
                android:orientation="vertical" />

        </androidx.drawerlayout.widget.DrawerLayout>

        <!-- Extra keys ViewPager (hidden by default, shown when toolbar toggled) -->
        <androidx.viewpager.widget.ViewPager
            android:id="@+id/terminal_toolbar_view_pager"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone" />

    </LinearLayout>

    <!-- 🔷 Bottom bar — exactly matching ParrotTerminal (48dp, weightSum=10, horizontal) -->
    <LinearLayout
        android:id="@+id/bottom_key_bar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:background="#ff0d1117"
        android:weightSum="10"
        android:paddingHorizontal="2dp">

        <!-- ── Ctrl button (weight 1.2) ── -->
        <LinearLayout
            android:id="@+id/btn_ctrl"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1.2"
            android:gravity="center"
            android:orientation="vertical"
            android:background="@drawable/bottom_key_bg"
            android:focusable="true"
            android:clickable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="8sp"
                android:textStyle="bold"
                android:textColor="#ff8b949e"
                android:text="@string/key_ctrl" />

            <TextView
                android:id="@+id/ctrl_indicator"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:background="@drawable/bottom_key_indicator_off"
                android:layout_marginTop="1dp" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="32dp"
            android:background="#ff30363d"
            android:layout_marginHorizontal="2dp" />

        <!-- ── Tab button (weight 1.2) ── -->
        <LinearLayout
            android:id="@+id/btn_tab"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1.2"
            android:gravity="center"
            android:orientation="vertical"
            android:background="@drawable/bottom_key_bg"
            android:focusable="true"
            android:clickable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="#ff50fa7b"
                android:text="⇥" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="7sp"
                android:textColor="#ff8b949e"
                android:text="@string/key_tab" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="32dp"
            android:background="#ff30363d"
            android:layout_marginHorizontal="2dp" />

        <!-- ── Middle section: Cut / Copy / Paste / Select (weight 3.4) ── -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="3.4"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btn_cut_material"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:padding="2dp"
                android:background="@drawable/bottom_key_bg"
                android:src="@drawable/ic_content_cut"
                android:scaleType="centerInside"
                android:contentDescription="@string/key_cut" />

            <ImageButton
                android:id="@+id/btn_copy_material"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:padding="2dp"
                android:background="@drawable/bottom_key_bg"
                android:src="@drawable/ic_content_copy"
                android:scaleType="centerInside"
                android:contentDescription="@string/key_copy"
                android:layout_marginHorizontal="1dp" />

            <ImageButton
                android:id="@+id/btn_paste_material"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:padding="2dp"
                android:background="@drawable/bottom_key_bg"
                android:src="@drawable/ic_content_paste"
                android:scaleType="centerInside"
                android:contentDescription="@string/key_paste" />

            <ImageButton
                android:id="@+id/btn_select_material"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:padding="2dp"
                android:background="@drawable/bottom_key_bg"
                android:src="@drawable/ic_select_all"
                android:scaleType="centerInside"
                android:contentDescription="@string/key_select" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="32dp"
            android:background="#ff30363d"
            android:layout_marginHorizontal="2dp" />

        <!-- ── Del button (weight 1) ── -->
        <LinearLayout
            android:id="@+id/btn_del"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:background="@drawable/bottom_key_bg"
            android:focusable="true"
            android:clickable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="#ffff6b6b"
                android:text="⌫" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="7sp"
                android:textColor="#ff8b949e"
                android:text="@string/key_del" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="32dp"
            android:background="#ff30363d"
            android:layout_marginHorizontal="2dp" />

        <!-- ── Cut button (weight 1) ── -->
        <LinearLayout
            android:id="@+id/btn_cut"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:background="@drawable/bottom_key_bg"
            android:focusable="true"
            android:clickable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="#ffffd93d"
                android:text="✂" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="7sp"
                android:textColor="#ff8b949e"
                android:text="@string/key_cut" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="32dp"
            android:background="#ff30363d"
            android:layout_marginHorizontal="2dp" />

        <!-- ── Paste button (weight 1) ── -->
        <LinearLayout
            android:id="@+id/btn_paste"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:background="@drawable/bottom_key_bg"
            android:focusable="true"
            android:clickable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="#ff50fa7b"
                android:text="📋" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="7sp"
                android:textColor="#ff8b949e"
                android:text="@string/key_paste" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="32dp"
            android:background="#ff30363d"
            android:layout_marginHorizontal="2dp" />

        <!-- ── Esc button (weight 1.2) ── -->
        <LinearLayout
            android:id="@+id/btn_esc"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1.2"
            android:gravity="center"
            android:orientation="vertical"
            android:background="@drawable/bottom_key_bg"
            android:focusable="true"
            android:clickable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#ffff79c6"
                android:text="@string/key_esc" />
        </LinearLayout>

    </LinearLayout>

    <!-- Bottom padding for system nav bar -->
    <View
        android:id="@+id/activity_termux_bottom_space_view"
        android:layout_width="match_parent"
        android:layout_height="0dp" />

</com.termux.app.terminal.TermuxActivityRootView>
