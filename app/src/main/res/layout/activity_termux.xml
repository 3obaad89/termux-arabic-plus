<?xml version="1.0" encoding="utf-8"?>
<com.termux.app.terminal.TermuxActivityRootView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/activity_termux_root_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#ff0d1117">

        <!-- Toolbar — exactly like ParrotTerminal -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:background="#ff0d1117"
            android:paddingStart="4dp"
            android:paddingEnd="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <TextView
                        android:id="@+id/app_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#ff50fa7b"
                        android:gravity="center_vertical"
                        android:text="@string/app_name" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:gravity="center_vertical"
                        android:text=" 🐉"
                        android:layout_marginStart="4dp" />
                </LinearLayout>

                <Space
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1" />

                <ImageButton
                    android:id="@+id/theme_sound_btn"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_theme_sound"
                    android:scaleType="center"
                    android:contentDescription="@string/change_theme"
                    android:layout_marginEnd="2dp" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/close_session_btn"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#ffff6b6b"
                    android:gravity="center"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:focusable="true"
                    android:clickable="true"
                    android:text="@string/close_session"
                    android:contentDescription="@string/close_session"
                    android:layout_marginEnd="24dp"
                    android:paddingHorizontal="10dp" />

                <ImageButton
                    android:id="@+id/settings_btn"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_settings"
                    android:scaleType="center"
                    android:contentDescription="@string/settings" />

            </LinearLayout>
        </com.google.android.material.appbar.MaterialToolbar>

        <!-- TabLayout — exactly like ParrotTerminal -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tab_layout"
            android:layout_width="match_parent"
            android:layout_height="26dp"
            android:background="#ff0d1117"
            android:elevation="1dp"
            app:tabIndicatorColor="#ff50fa7b"
            app:tabIndicatorHeight="2dp"
            app:tabMaxWidth="90dp"
            app:tabMinWidth="48dp"
            app:tabMode="scrollable"
            app:tabPaddingEnd="4dp"
            app:tabPaddingStart="4dp"
            app:tabSelectedTextColor="#ff50fa7b"
            app:tabTextColor="#ff8b949e" />

        <!-- Terminal area — replaces ViewPager2 -->
        <RelativeLayout
            android:id="@+id/activity_termux_root_relative_layout"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingHorizontal="4dp">

            <androidx.drawerlayout.widget.DrawerLayout
                android:id="@+id/drawer_layout"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_alignParentTop="true"
                android:layout_alignParentBottom="true">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <com.termux.view.TerminalView
                        android:id="@+id/terminal_view"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:defaultFocusHighlightEnabled="false"
                        android:scrollbarStyle="insideOverlay"
                        android:scrollbarThumbVertical="@drawable/terminal_scroll_shape"
                        android:layout_alignParentTop="true"
                        android:layout_alignParentBottom="true" />

                    <androidx.viewpager.widget.ViewPager
                        android:id="@+id/terminal_toolbar_view_pager"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_alignParentBottom="true"
                        android:visibility="gone" />

                </RelativeLayout>

                <!-- Session list drawer -->
                <ListView
                    android:id="@+id/terminal_sessions_list"
                    android:layout_width="240dp"
                    android:layout_height="match_parent"
                    android:layout_gravity="start"
                    android:choiceMode="singleChoice"
                    android:background="#ff161b22" />

            </androidx.drawerlayout.widget.DrawerLayout>

        </RelativeLayout>

        <!-- Bottom key bar — exactly like ParrotTerminal -->
        <LinearLayout
            android:id="@+id/arrow_toolbar"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:background="#ff0d1117"
            android:weightSum="10"
            android:paddingHorizontal="2dp">

            <!-- Ctrl button -->
            <LinearLayout
                android:id="@+id/btn_ctrl"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1.2"
                android:gravity="center"
                android:orientation="vertical"
                android:background="@drawable/btn_key_bg"
                android:focusable="true"
                android:clickable="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="8sp"
                    android:textStyle="bold"
                    android:textColor="#ff8b949e"
                    android:text="Ctrl" />
                <TextView
                    android:id="@+id/ctrl_indicator"
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:background="@drawable/circle_off"
                    android:layout_marginTop="1dp" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="32dp"
                android:background="#ff30363d"
                android:layout_marginHorizontal="2dp" />

            <!-- Tab button -->
            <LinearLayout
                android:id="@+id/btn_tab"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1.2"
                android:gravity="center"
                android:orientation="vertical"
                android:background="@drawable/btn_key_bg"
                android:focusable="true"
                android:clickable="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textColor="#ff50fa7b"
                    android:text="⇥" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="7sp"
                    android:textColor="#ff8b949e"
                    android:text="Tab" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="32dp"
                android:background="#ff30363d"
                android:layout_marginHorizontal="2dp" />

            <!-- Arrow keys -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="3.4"
                android:gravity="center"
                android:orientation="horizontal">
                <ImageButton
                    android:id="@+id/arrow_left"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:padding="2dp"
                    android:background="@drawable/btn_key_bg"
                    android:src="@drawable/ic_arrow_left"
                    android:scaleType="center" />
                <ImageButton
                    android:id="@+id/arrow_up"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:padding="2dp"
                    android:background="@drawable/btn_key_bg"
                    android:src="@drawable/ic_arrow_up"
                    android:scaleType="center"
                    android:layout_marginHorizontal="1dp" />
                <ImageButton
                    android:id="@+id/arrow_down"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:padding="2dp"
                    android:background="@drawable/btn_key_bg"
                    android:src="@drawable/ic_arrow_down"
                    android:scaleType="center" />
                <ImageButton
                    android:id="@+id/arrow_right"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:padding="2dp"
                    android:background="@drawable/btn_key_bg"
                    android:src="@drawable/ic_arrow_right"
                    android:scaleType="center" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="32dp"
                android:background="#ff30363d"
                android:layout_marginHorizontal="2dp" />

            <!-- Del button -->
            <LinearLayout
                android:id="@+id/btn_del"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:background="@drawable/btn_key_bg"
                android:focusable="true"
                android:clickable="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="#ffff6b6b"
                    android:text="⌫" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="7sp"
                    android:textColor="#ff8b949e"
                    android:text="Del" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="32dp"
                android:background="#ff30363d"
                android:layout_marginHorizontal="2dp" />

            <!-- Cut button -->
            <LinearLayout
                android:id="@+id/btn_cut"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:background="@drawable/btn_key_bg"
                android:focusable="true"
                android:clickable="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="#ffffd93d"
                    android:text="✂" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="7sp"
                    android:textColor="#ff8b949e"
                    android:text="Cut" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="32dp"
                android:background="#ff30363d"
                android:layout_marginHorizontal="2dp" />

            <!-- Paste button -->
            <LinearLayout
                android:id="@+id/btn_paste"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:background="@drawable/btn_key_bg"
                android:focusable="true"
                android:clickable="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="#ff50fa7b"
                    android:text="📋" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="7sp"
                    android:textColor="#ff8b949e"
                    android:text="Paste" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="32dp"
                android:background="#ff30363d"
                android:layout_marginHorizontal="2dp" />

            <!-- Esc button -->
            <LinearLayout
                android:id="@+id/btn_esc"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1.2"
                android:gravity="center"
                android:orientation="vertical"
                android:background="@drawable/btn_key_bg"
                android:focusable="true"
                android:clickable="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="#ffff79c6"
                    android:text="Esc" />
            </LinearLayout>

        </LinearLayout>

        <!-- Bottom space view for nav bar -->
        <View
            android:id="@+id/activity_termux_bottom_space_view"
            android:layout_width="match_parent"
            android:layout_height="0dp" />

    </LinearLayout>

</com.termux.app.terminal.TermuxActivityRootView>
